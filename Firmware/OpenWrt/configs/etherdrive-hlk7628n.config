# PS2-EtherDrive OpenWrt preset for HLK-7628N development builds
#
# TODO: Verify exact HLK-7628N OpenWrt device profile symbol.
# TODO: Verify final DTS/device-tree selection for production board revisions.
# TODO: Verify flash layout/size constraints before release profile hardening.
# TODO: Verify factory partition handling and recovery-safe image format.

CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt76x8=y
# TODO: Confirm this profile symbol against the exact OpenWrt release used by CI/build hosts.
CONFIG_TARGET_ramips_mt76x8_DEVICE_hilink_hlk_7628n=y

# Base services
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_block-mount=y

# USB 2.0 storage and filesystem support
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_dosfstools=y
CONFIG_PACKAGE_blkid=y

# Network / WiFi essentials
CONFIG_PACKAGE_wpad-basic-mbedtls=y
CONFIG_PACKAGE_kmod-mt7603=y

# SMB1/NT1 compatibility for PS2 OPL
CONFIG_PACKAGE_samba36-server=y

# EtherDrive custom packages
CONFIG_PACKAGE_udpfsd=y
CONFIG_PACKAGE_etherdrive-core=y
CONFIG_PACKAGE_etherdrive-webui=y
CONFIG_PACKAGE_etherdrive-smb1=y
CONFIG_PACKAGE_etherdrive-udpfs=y
CONFIG_PACKAGE_etherdrive-udpbd=y
