#!/bin/sh

echo "Content-Type: application/json"
echo ""

action=""
post_data=""

url_decode() {
	data="$(printf '%s' "$1" | sed 's/+/ /g')"
	printf '%b' "$(printf '%s' "$data" | sed 's/%/\\x/g')"
}

get_param() {
	key="$1"
	source="$2"
	OLDIFS="$IFS"
	IFS='&'
	for pair in $source; do
		k="${pair%%=*}"
		v="${pair#*=}"
		k="$(url_decode "$k")"
		if [ "$k" = "$key" ]; then
			url_decode "$v"
			IFS="$OLDIFS"
			return 0
		fi
	done
	IFS="$OLDIFS"
	return 1
}

read_post() {
	if [ "${REQUEST_METHOD:-}" = "POST" ] && [ -n "${CONTENT_LENGTH:-}" ]; then
		read -r post_data || true
	fi
}

json_array_from_lines() {
	first=1
	echo -n '['
	while IFS= read -r line; do
		[ -n "$line" ] || continue
		[ "$first" -eq 1 ] || echo -n ','
		first=0
		line_esc="$(printf '%s' "$line" | sed 's/\\/\\\\/g; s/"/\\"/g')"
		echo -n "\"$line_esc\""
	done
	echo -n ']'
}

save_setup() {
	ssid="$(get_param wifi_ssid "$post_data" || true)"
	pw="$(get_param wifi_password "$post_data" || true)"
	ip="$(get_param ps2_ip "$post_data" || true)"
	gw="$(get_param gateway "$post_data" || true)"
	sub="$(get_param subnet "$post_data" || true)"

	[ -n "$ip" ] || ip="192.168.1.199"
	[ -n "$gw" ] || gw="192.168.1.1"
	[ -n "$sub" ] || sub="255.255.255.0"

	uci set etherdrive.main.first_boot_done='1'
	uci set etherdrive.main.wifi_ssid="$ssid"
	uci set etherdrive.main.ps2_ip="$ip"
	uci set etherdrive.main.gateway="$gw"
	uci set etherdrive.main.subnet="$sub"
	uci commit etherdrive

	uci -q set network.lan.proto='static' || true
	uci -q set network.lan.ipaddr="$ip" || true
	uci -q set network.lan.gateway="$gw" || true
	uci -q set network.lan.netmask="$sub" || true
	uci -q commit network || true

	if [ -n "$ssid" ]; then
		uci -q set wireless.@wifi-iface[0].ssid="$ssid" || true
		if [ -n "$pw" ]; then
			uci -q set wireless.@wifi-iface[0].encryption='psk2' || true
			uci -q set wireless.@wifi-iface[0].key="$pw" || true
		fi
		uci -q commit wireless || true
	fi
}

read_post
query="${QUERY_STRING:-}"
action="$(get_param action "$query" || true)"

case "$action" in
	status)
		/usr/bin/etherdrive-status 2>/dev/null || echo '{"ok":false,"message":"status unavailable"}'
		;;
	wifi_scan)
		if command -v iwinfo >/dev/null 2>&1; then
			ssids="$(
				{
					iwinfo wlan0 scan 2>/dev/null || iwinfo 2>/dev/null
				} | sed -n 's/.*ESSID: \"\\(.*\\)\"/\\1/p' | awk 'NF && !seen[$0]++'
			)"
			echo -n '{"ok":true,"ssids":'
			printf '%s\n' "$ssids" | json_array_from_lines
			echo '}'
		else
			echo '{"ok":false,"ssids":[],"message":"iwinfo not found"}'
		fi
		;;
	setup_save)
		save_setup
		echo '{"ok":true,"message":"Setup saved. Apply network changes manually or reboot."}'
		;;
	setup_reboot)
		save_setup
		( sleep 2; reboot ) >/dev/null 2>&1 &
		echo '{"ok":true,"message":"Setup saved. Rebooting..."}'
		;;
	set_mode)
		mode="$(get_param mode "$post_data" || true)"
		if /usr/bin/etherdrive-mode set "$mode" >/dev/null 2>&1; then
			echo '{"ok":true,"message":"Mode updated."}'
		else
			echo '{"ok":false,"message":"Failed to set mode."}'
		fi
		;;
	storage_list)
		echo -n '{"ok":true,"devices":'
		/usr/bin/etherdrive-storage list-devices 2>/dev/null | json_array_from_lines
		echo '}'
		;;
	storage_status)
		st_json="$(/usr/bin/etherdrive-storage status 2>/dev/null || true)"
		case "$st_json" in
			\{*\})
				printf '{"ok":true,"storage":%s}\n' "$st_json"
				;;
			*)
				echo '{"ok":false,"message":"storage status unavailable","storage":{}}'
				;;
		esac
		;;
	storage_save)
		dev="$(get_param storage_device "$post_data" || true)"
		mnt="$(get_param storage_mount "$post_data" || true)"
		share="$(get_param share_name "$post_data" || true)"
		auto="$(get_param auto_mount "$post_data" || true)"
		/usr/bin/etherdrive-storage set "$dev" "$mnt" "$share" "$auto" >/dev/null 2>&1 || true
		/usr/bin/etherdrive-storage ensure-mounted >/dev/null 2>&1 || true
		echo '{"ok":true,"message":"Storage settings saved."}'
		;;
	update_status)
		fw="$(. /etc/openwrt_release 2>/dev/null; echo "${DISTRIB_DESCRIPTION:-unknown}")"
		channel="$(uci -q get etherdrive.main.update_channel || echo stable)"
		fw_esc="$(printf '%s' "$fw" | sed 's/"/\\"/g')"
		echo "{\"ok\":true,\"firmware_version\":\"$fw_esc\",\"update_channel\":\"$channel\"}"
		;;
	update_flash_placeholder)
		reboot_after="$(get_param reboot_after "$post_data" || echo 0)"
		echo "{\"ok\":true,\"message\":\"Flash placeholder only. sysupgrade not connected yet. reboot_after=$reboot_after\"}"
		;;
	*)
		echo '{"ok":false,"message":"Unknown action"}'
		;;
esac
