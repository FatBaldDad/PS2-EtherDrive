#!/bin/sh

set -eu

cfg_get() {
	uci -q get "etherdrive.main.$1" || true
}

list_devices() {
	for dev in /dev/sd[a-z][0-9] /dev/sd[a-z] /dev/mmcblk[0-9]p[0-9] /dev/mmcblk[0-9]; do
		[ -b "$dev" ] && echo "$dev"
	done | awk '!seen[$0]++'
}

is_mounted() {
	mount_point="$1"
	grep -qs " $mount_point " /proc/mounts
}

ensure_mounted() {
	local device mount_path share_name auto_mount share_path
	device="$(cfg_get storage_device)"
	mount_path="$(cfg_get storage_mount)"
	share_name="$(cfg_get share_name)"
	auto_mount="$(cfg_get auto_mount)"

	[ -n "$mount_path" ] || mount_path="/mnt/etherdrive"
	[ -n "$share_name" ] || share_name="PS2SMB"
	[ -n "$auto_mount" ] || auto_mount="1"

	mkdir -p "$mount_path"

	if [ -n "$device" ] && [ "$auto_mount" = "1" ] && ! is_mounted "$mount_path"; then
		if [ -b "$device" ]; then
			mount "$device" "$mount_path" >/dev/null 2>&1 || true
		fi
	fi

	share_path="$mount_path/$share_name"
	mkdir -p "$share_path"
}

status_json() {
	local device mount_path share_name auto_mount share_path mounted
	device="$(cfg_get storage_device)"
	mount_path="$(cfg_get storage_mount)"
	share_name="$(cfg_get share_name)"
	auto_mount="$(cfg_get auto_mount)"

	[ -n "$mount_path" ] || mount_path="/mnt/etherdrive"
	[ -n "$share_name" ] || share_name="PS2SMB"
	[ -n "$auto_mount" ] || auto_mount="1"
	share_path="$mount_path/$share_name"

	if is_mounted "$mount_path"; then
		mounted="yes"
	else
		mounted="no"
	fi

	printf '{"storage_device":"%s","storage_mount":"%s","share_path":"%s","auto_mount":"%s","mounted":"%s"}' \
		"$device" "$mount_path" "$share_path" "$auto_mount" "$mounted"
}

set_config() {
	local device mount_path share_name auto_mount
	device="${1:-}"
	mount_path="${2:-/mnt/etherdrive}"
	share_name="${3:-PS2SMB}"
	auto_mount="${4:-1}"

	uci set etherdrive.main.storage_device="$device"
	uci set etherdrive.main.storage_mount="$mount_path"
	uci set etherdrive.main.share_name="$share_name"
	uci set etherdrive.main.auto_mount="$auto_mount"
	uci commit etherdrive
}

case "${1:-status}" in
	list-devices)
		list_devices
		;;
	ensure-mounted)
		ensure_mounted
		;;
	status)
		status_json
		;;
	set)
		set_config "${2:-}" "${3:-}" "${4:-}" "${5:-}"
		echo ok
		;;
	*)
		echo "Usage: $0 [status|list-devices|ensure-mounted|set DEVICE MOUNT SHARE AUTO]" >&2
		exit 1
		;;
esac
