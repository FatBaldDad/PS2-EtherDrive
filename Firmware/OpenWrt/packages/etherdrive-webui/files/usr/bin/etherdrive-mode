#!/bin/sh

set -eu

SERVICE_SAMBA="/etc/init.d/samba"
SERVICE_UDPFSD="/etc/init.d/udpfsd"

get_cfg() {
	uci -q get "etherdrive.main.$1" || true
}

set_cfg() {
	uci set "etherdrive.main.$1=$2"
}

apply_mode() {
	local mode storage_mount share_name share_path
	mode="$(get_cfg mode)"
	[ -n "$mode" ] || mode="wifi_only"

	storage_mount="$(get_cfg storage_mount)"
	share_name="$(get_cfg share_name)"
	[ -n "$storage_mount" ] || storage_mount="/mnt/etherdrive"
	[ -n "$share_name" ] || share_name="PS2SMB"
	share_path="$storage_mount/$share_name"

	if [ -x /usr/bin/etherdrive-storage ]; then
		/usr/bin/etherdrive-storage ensure-mounted >/dev/null 2>&1 || true
	fi
	mkdir -p "$share_path"

	[ -x "$SERVICE_SAMBA" ] && "$SERVICE_SAMBA" stop >/dev/null 2>&1 || true
	[ -x "$SERVICE_UDPFSD" ] && "$SERVICE_UDPFSD" stop >/dev/null 2>&1 || true

	uci -q set samba.@samba[0].enabled='0' || true
	uci -q set udpfsd.main.enabled='0' || true
	uci -q commit samba || true
	uci -q commit udpfsd || true

	case "$mode" in
		wifi_only)
			;;
		smb1)
			uci -q set samba.@sambashare[0].path="$share_path" || true
			uci -q set samba.@samba[0].enabled='1' || true
			uci -q commit samba || true
			[ -x "$SERVICE_SAMBA" ] && "$SERVICE_SAMBA" start >/dev/null 2>&1 || true
			;;
		udpbd|udpfs)
			uci -q set udpfsd.main.fsroot="$share_path" || true
			uci -q set udpfsd.main.enabled='1' || true
			uci -q commit udpfsd || true
			[ -x "$SERVICE_UDPFSD" ] && "$SERVICE_UDPFSD" start >/dev/null 2>&1 || true
			;;
		*)
			echo "Invalid mode: $mode" >&2
			return 1
			;;
	esac
}

case "${1:-get}" in
	get)
		mode="$(get_cfg mode)"
		[ -n "$mode" ] || mode="wifi_only"
		echo "$mode"
		;;
	set)
		new_mode="${2:-}"
		case "$new_mode" in
			wifi_only|smb1|udpbd|udpfs) ;;
			*)
				echo "Usage: $0 set {wifi_only|smb1|udpbd|udpfs}" >&2
				exit 1
				;;
		esac
		set_cfg mode "$new_mode"
		uci commit etherdrive
		apply_mode
		echo "$new_mode"
		;;
	apply)
		apply_mode
		;;
	*)
		echo "Usage: $0 [get|set MODE|apply]" >&2
		exit 1
		;;
esac
