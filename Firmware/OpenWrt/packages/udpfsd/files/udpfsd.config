# /etc/config/udpfsd
#
# Configuration for the udpfsd UDPFS/UDPBD server
# (PS2-EtherDrive optional third-party service)
#
# Original project: https://github.com/pcm720/udpfsd
# Author: Ivan V (pcm720) — License: BSD-3-Clause
#
# NOTE: The service is DISABLED by default.
#
# To enable, set 'enabled' to '1' and configure a storage source:
#
#   Method A — serve from a USB or microSD block device:
#     Set 'device' to the block device (e.g. /dev/sda1 or /dev/mmcblk0p1).
#     The init script will mount it at 'mount_point' and serve 'fsroot'.
#     If 'fsroot' is left empty it defaults to 'mount_point'.
#
#   Method B — serve from an already-mounted path:
#     Leave 'device' empty, set 'fsroot' to the directory to serve.
#
# PS2-EtherDrive mode selection:
#   UDPFS mode is intended for Neutrino / NHDDL-style PS2 game loading.
#   To switch between SMB1, FTP, and UDPFS modes, adjust this config and
#   the corresponding SMB/FTP service configs, then restart the services.
#

config udpfsd 'main'
	# Set to '1' to enable the service on boot
	option enabled        '0'

	# Block device to mount before starting (e.g. /dev/sda1, /dev/mmcblk0p1)
	# Leave empty if the path is already mounted or managed elsewhere
	option device         ''

	# Where to mount the storage device (used only when 'device' is set)
	option mount_point    '/mnt/udpfs'

	# Root directory to serve to the PS2.
	# Leave empty to default to 'mount_point' when 'device' is set.
	option fsroot         ''

	# UDP port for discovery and data (default matches Neutrino default)
	option port           '62966'

	# Serve in read-only mode (recommended; set to '0' only if writes are needed)
	option read_only      '1'

	# Enable verbose server logging to syslog
	option verbose        '0'
