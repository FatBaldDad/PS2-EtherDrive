# /etc/config/samba
#
# PS2-EtherDrive SMB1 profile for PlayStation 2 OPL compatibility.
#
# SECURITY WARNING:
# SMB1/NT1 is legacy and insecure. Use this mode only on a local trusted PS2
# network segment. Do not expose this service to the internet.
#
# Service is disabled by default and should only be enabled when SMB mode is
# selected on PS2-EtherDrive.
#
# Storage path defaults to USB. For microSD installs, change path to a mounted
# microSD location (for example: /mnt/sdcard/PS2SMB).
#

config samba
	option name 'PS2_EtherDrive'
	option workgroup 'WORKGROUP'
	option description 'PS2 SMB1 Service (Trusted LAN Only)'
	option homes '0'
	option interface 'lan'
	option enabled '0'

config sambashare
	option name 'PS2SMB'
	option path '/mnt/usb/PS2SMB'
	option read_only 'no'
	option guest_ok 'yes'
	option browseable 'yes'
	option create_mask '0644'
	option dir_mask '0755'
